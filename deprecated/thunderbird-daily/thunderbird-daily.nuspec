<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>thunderbird-daily</id>
    <version>999.0.0</version>
    <title>[DEPRECATED] Mozilla Thunderbird Nightly (Daily)</title>
    <authors>Mozilla</authors>
    <owners>DEUS-DEI</owners>
    <projectUrl>https://www.thunderbird.net/en-US/channel/</projectUrl>
    <iconUrl>https://www.thunderbird.net/media/img/thunderbird/logos/daily.png</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>
### IMPORTANT - NAME CHANGE
This package has been renamed to **thunderbird-nightly** to comply with Chocolatey's Package ID naming conventions.
Installing this version will automatically install the new package as a dependency.
    </description>
    <summary>Transitional package towards thunderbird-nightly</summary>
    <tags>deprecated thunderbird</tags>
    <dependencies>
      <dependency id="thunderbird-nightly" />
    </dependencies>
  </metadata>
</package>
